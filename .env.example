# EmailJS — contact form delivery
# Get these from https://www.emailjs.com/ (Dashboard → Email Services, Email Templates, Account → API Keys)
#
# Contact form template variables:
#   {{from_name}}, {{reply_to}}, {{company_name}}, {{project_scope}}, {{budget}}
#
# Express Service Portal template variables (optional separate template):
#   {{service_type}}, {{project_brief}}, {{estimated_fee}}, {{payment_status}}
#
# Restart `npm run dev` after saving this file as `.env.local`

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: dedicated template for Express Service Portal (falls back to TEMPLATE_ID above)
NEXT_PUBLIC_EMAILJS_SERVICE_REQUEST_TEMPLATE_ID=your_service_request_template_id

# PayPal payment link (PayPal.me, hosted button URL, or checkout link)
NEXT_PUBLIC_PAYPAL_PAYMENT_URL=https://www.paypal.com/paypalme/your_link
